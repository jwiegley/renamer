            "content": "#!/usr/bin/env bash\nset -euo pipefail\n\n# Run tests with coverage enabled\ncabal test -j --enable-coverage --test-show-details=direct 2>&1\n\n# Find the tix file generated by the test run\nTIX=$(find dist-newstyle -name 'renamer-tests.tix' 2>/dev/null | head -1)\nif [ -z \"$TIX\" ]; then\n  echo \"WARNING: No coverage data found\"\n  exit 0\nfi\n\n# Extract expression coverage percentage\nCOVERAGE=$(hpc report \"$TIX\" --auto-all 2>/dev/null \\\n  | grep 'expressions used' \\\n  | grep -oE '[0-9]+' \\\n  | head -1)\n\nif [ -z \"$COVERAGE\" ]; then\n  echo \"WARNING: Could not parse coverage data\"\n  exit 0\nfi\n\necho \"Coverage: ${COVERAGE}% expressions used\"\n\n# Check against stored threshold\nTHRESHOLD=$(cat .coverage-threshold 2>/dev/null || echo \"0\")\nif [ \"$COVERAGE\" -lt \"$THRESHOLD\" ]; then\n  echo \"ERROR: Coverage dropped from ${THRESHOLD}% to ${COVERAGE}%\"\n  exit 1\nfi\n\n# Ratchet: update threshold if coverage improved\nif [ \"$COVERAGE\" -gt \"$THRESHOLD\" ]; then\n  echo \"$COVERAGE\" > .coverage-threshold\n  echo \"Updated coverage threshold to ${COVERAGE}%\"\nfi\n",
